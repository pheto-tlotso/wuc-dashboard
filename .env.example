# WUC NRW Dashboard — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# AWS Configuration
# Obtain from your team lead — do not share or commit
AWS_S3_BUCKET=
AWS_DEFAULT_REGION=

# Local development override
# Set to "true" to load model artefacts from ./models/ instead of S3
USE_LOCAL_MODELS=false

# Streamlit config (optional)
# STREAMLIT_SERVER_PORT=8501
